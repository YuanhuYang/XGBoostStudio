# ============================================================
# XGBoost Studio .gitignore
# ============================================================

# 构建产物
build/
dist/
client/dist/
server/dist/

# 打包后的二进制文件（超出 GitHub 100MB 限制）
client/resources/*.exe
client/resources/*.dll
server/dist/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# uv 虚拟环境（不提交，但 pyproject.toml 和 uv.lock 需提交）
.venv/
venv/
server/.venv/

# Node
node_modules/
client/node_modules/
# TypeScript 增量编译缓存（勿提交）
*.tsbuildinfo

# 运行时数据（用户数据，不入库）
*.db
*.sqlite
# 仅忽略仓库根目录下的 data/（勿用 data/ 以免误伤 server/tests/data）
/data/
logs/
*.log

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/

# Cursor：`.cursor/`（规则、Skills、提示词）**纳入版本库**供克隆协作者共享；请勿将 `.cursor/` 加入忽略。
*.suo
*.user

# 密钥/证书/环境变量
*.pem
*.key
*.p12
.env
.env.local

# PyInstaller 临时文件
*.spec.bak

# electron-builder 缓存
client/.electron-builder-cache/

# E2E 脚本落盘 PDF（本地验证产物，勿提交）
server/tests/e2e_test_report.pdf

# Playwright MCP 工具运行时产物
.playwright-mcp/

client/out/
client/dist-electron/
# 本地/CI 临时与构建旁路产物（勿提交）
.tmp_rl/
client/dist-renderer/
server/.pytest_data_*/

# Playwright E2E 截图产物（文档用图除外，保留 .gitkeep）
client/e2e/screenshots/**/*.png
!client/e2e/screenshots/.gitkeep

# 文档中临时截图，仅保留固定文档用图
docs/assets/screenshots/**/*
!docs/assets/screenshots/**/.gitkeep

# Playwright E2E GIF 录制品（文档用GIF除外，保留 .gitkeep）
client/e2e/recordings/**/*.webm
client/e2e/recordings/**/*.gif
!client/e2e/recordings/.gitkeep

# 文档中临时 GIF，仅保留固定文档用 GIF
docs/assets/gifs/**/*
!docs/assets/gifs/**/.gitkeep

# 测试覆盖率报告
client/coverage/

# Playwright 测试报告产物
client/playwright-report/
client/test-results/
